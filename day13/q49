//A program to input and display array

#include <stdio.h>

int main() {
    int size, i;
    printf("Enter the size of the array: ");
    scanf("%d", &size);

    int array[size];

    printf("Enter %d integers:\n", size);
    for (i = 0; i < size; i++) {
        scanf("%d", &array[i]);
    }

    printf("The elements of the array are:\n");
    for (i = 0; i < size; i++) {
        printf("%d ", array[i]);
    }

    return 0;
}