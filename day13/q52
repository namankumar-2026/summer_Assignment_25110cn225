//A program to count even and odd elements

#include <stdio.h>
int main() {
    int size, evenCount = 0, oddCount = 0;
    
    printf("Enter the size of the array: ");
    scanf("%d", &size);
    
    int array[size];
    
    printf("Enter %d integers:\n", size);
    for (int i = 0; i < size; i++) {
        scanf("%d", &array[i]);
    }
    
    for (int i = 0; i < size; i++) {
        if (array[i] % 2 == 0) {
            evenCount++; // Increment even count if element is even
        } else {
            oddCount++; // Increment odd count if element is odd
        }
    }
    
    printf("The number of even elements in the array is: %d\n", evenCount);
    printf("The number of odd elements in the array is: %d\n", oddCount);
    
    return 0;
}