//A program to find common characters in strings

#include <stdio.h>
int main() {
    char str1[100], str2[100], common[100];
    int i, j, k = 0, found;

    printf("Enter first string: ");
    fgets(str1, sizeof(str1), stdin);
    printf("Enter second string: ");
    fgets(str2, sizeof(str2), stdin);

    for (i = 0; str1[i] != '\0'; i++) {
        found = 0;
        for (j = 0; str2[j] != '\0'; j++) {
            if (str1[i] == str2[j]) {
                found = 1;
                break;
            }
        }
        if (found) {
            common[k++] = str1[i];
        }
    }
    common[k] = '\0';

    printf("Common characters: %s\n", common);
    return 0;
}