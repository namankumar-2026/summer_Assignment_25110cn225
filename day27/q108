// 12. Function to display students with marks above a certain threshold in a specific subject
void displayStudentsAboveMarksInSubject() {
    if (studentCount == 0) {
        printf("\nNo student records found to display.\n");
        return;
    }

    int subjectIndex;
    float threshold;
    printf("\nEnter the subject index (1-5): ");
    scanf("%d", &subjectIndex);
    if (subjectIndex < 1 || subjectIndex > 5) {
        printf("Invalid subject index! Please enter a value between 1 and 5.\n");
        return;
    }

    printf("Enter the marks threshold: ");
    scanf("%f", &threshold);

    printf("\nStudents with marks above %.2f in subject %d:\n", threshold, subjectIndex);
    printf("%-10s %-25s %-10s %-10s %-5s\n", "ID", "Name", "Branch", "Total Marks", "CGPA");
    printf("---------------------------------------------------------------\n");
    int found = 0;
    for (int i = 0; i < studentCount; i++) {
        if (students[i].marks[subjectIndex - 1] > threshold) {
            printf("%-10d %-25s %-10s %-10.2f %-5.2f\n", students[i].id, students[i].name, students[i].branch, students[i].total, students[i].cgpa);
            found = 1;
        }
    }
    if (!found) {
        printf("No students found with marks above %.2f in subject %d.\n", threshold, subjectIndex);
    }
}

