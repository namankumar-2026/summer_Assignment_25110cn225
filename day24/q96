// A program to remove duplicate characters from a string

#include <stdio.h>
#include <string.h>
int main() {
    char str[100], result[100];
    int i, j = 0, len;
    int freq[256] = {0};

    printf("Enter a string: ");
    fgets(str, sizeof(str), stdin);

    len = strlen(str) - 1; // Exclude the newline character

    for (i = 0; i < len; i++) {
        if (freq[str[i]] == 0) {
            result[j++] = str[i];
            freq[str[i]] = 1;
        }
    }
    result[j] = '\0';

    printf("String after removing duplicates: %s\n", result);
    return 0;
}