//A program to find diagonal sum

#include<stdio.h>

int main(){
    int a[10][10], i, j, r, s, sum=0;
    printf("Enter the number of rows and columns of the matrix: ");
    scanf("%d %d", &r, &s);
    printf("Enter the elements of the matrix: ");
    for(i=0; i<r; i++){
        for(j=0; j<s; j++){
            scanf("%d", &a[i][j]);
        }
    }
    for(i=0; i<r; i++){
        for(j=0; j<s; j++){
            if(i==j){
                sum += a[i][j];
            }
        }
    }
    printf("The sum of the diagonal elements is: %d", sum);
    return 0;
}