//A program to transpose matrices

#include<stdio.h>

int main(){
    int a[10][10], b[10][10], i, j, r, s;
    printf("Enter the number of rows and columns of the matrix: ");
    scanf("%d %d", &r, &s);
    printf("Enter the elements of the matrix: ");
    for(i=0; i<r; i++){
        for(j=0; j<s; j++){
            scanf("%d", &a[i][j]);
        }
    }
    for(i=0; i<r; i++){
        for(j=0; j<s; j++){
            b[j][i] = a[i][j];
        }
    }
    printf("The transpose of the matrix is: \n");
    for(i=0; i<s; i++){
        for(j=0; j<r; j++){
            printf("%d ", b[i][j]);
        }
        printf("\n");
    }
    return 0;
}