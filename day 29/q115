//A program to Create menu-driven string operations system

#include<stdio.h>
#include<string.h>

#define MAX_SIZE 100

// Function declarations
void concatenateStrings(char str1[], char str2[]);

int main() {
    char str1[MAX_SIZE], str2[MAX_SIZE];
    int choice;

    while (1) {
        printf("\n=== Menu-Driven String Operations ===\n");
        printf("1. Concatenate Strings\n");
        printf("2. Exit\n");
        printf("Enter your choice (1-2): ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter first string: ");
                scanf(" %[^\n]%*c", str1);
                printf("Enter second string: ");
                scanf(" %[^\n]%*c", str2);
                concatenateStrings(str1, str2);
                break;
            case 2:
                printf("Exiting program. Goodbye!\n");
                return 0;
            default:
                printf("Invalid choice! Please try again.\n");
        }
    }

    return 0;
}


// Function to concatenate two strings
void concatenateStrings(char str1[], char str2[]) {
    char result[MAX_SIZE * 2]; // Ensure enough space for concatenated string
    strcpy(result, str1);
    strcat(result, str2);
    printf("Concatenated String: %s\n", result);
}

// This program implements a menu-driven string operations system that allows the user to concatenate two strings. 
// The user can choose to concatenate strings or exit the program. The program continues to run until the user chooses to exit.


