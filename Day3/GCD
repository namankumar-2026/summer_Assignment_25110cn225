//A program to find the GCD of two numbers with comments
#include<stdio.h>
int main()
{
    int num1, num2, gcd;
    printf("Enter two positive integers: ");
    scanf("%d %d", &num1, &num2);
    
    // Loop from 1 to the smaller of num1 and num2
    for (int i = 1; i <= num1 && i <= num2; i++) {
        // Check if i is a factor of both num1 and num2
        if (num1 % i == 0 && num2 % i == 0) {
            gcd = i; // Update gcd to the current factor
        }
    }
    
    printf("The GCD of %d and %d is: %d\n", num1, num2, gcd);
    return 0;
}