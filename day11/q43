//A program to write function to check prime with comments in the code

#include<stdio.h>
int isPrime(int num)
{
    if (num <= 1) // Check if the number is less than or equal to 1
        return 0; // Not prime

    for (int i = 2; i <= num / 2; i++) // Loop from 2 to half of the number
    {
        if (num % i == 0) // Check if the number is divisible by any of these numbers
            return 0; // Not prime
    }
    return 1; // Prime
}
int main()
{
    int num;
    printf("Enter a number: "); // Prompt the user to enter a number
    scanf("%d", &num); // Read the number from the user

    if (isPrime(num)) // Call the isPrime function and check its return value
        printf("%d is a prime number.\n", num); // If true, print that it is a prime number
    else
        printf("%d is not a prime number.\n", num); // If false, print that it is not a prime number

    return 0; 
}
