//A program to write function to find factorial

#include<stdio.h>
int factorial(int n)
{
    if (n == 0 || n == 1) // Base case: factorial of 0 or 1 is 1
        return 1;
    else
        return n * factorial(n - 1); // Recursive case: n! = n * (n-1)!
}
int main()
{
    int num;
    printf("Enter a number: "); // Prompt the user to enter a number
    scanf("%d", &num); // Read the number from the user

    if (num < 0) // Check if the number is negative
        printf("Factorial is not defined for negative numbers.\n"); // Inform the user that factorial is not defined for negative numbers
    else
    {
        int result = factorial(num); // Call the factorial function and store the result
        printf("The factorial of %d is: %d\n", num, result); // Print the factorial of the number
    }

    return 0; 
}