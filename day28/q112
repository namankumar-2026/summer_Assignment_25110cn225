    printf("\nContacts with Email Domain '%s':\n", searchDomain);
    printf("%-30s %-15s %-50s\n", "Name", "Phone", "Email");
    printf("-------------------------------------------------------------------------------\n");
    int found = 0;
    for (int i = 0; i < contact_count; i++) {
        char *domain = strchr(contacts[i].email, '@');
        if (domain != NULL && strcmp(domain + 1, searchDomain) == 0) {
            printf("%-30s %-15s %-50s\n", contacts[i].name, contacts[i].phone, contacts[i].email);
            found = 1;
        }
    }
    if (!found) {
        printf("No contacts found with email domain '%s'.\n", searchDomain);
    }
}

