    printf("-------------------------------------------------------------------------------\n");
    int found = 0;
    for (int i = 0; i < contact_count; i++) {
        int nameLength = strlen(contacts[i].name);
        int substringLength = strlen(searchSubstring);
        if (nameLength >= substringLength && strcmp(contacts[i].name + nameLength - substringLength, searchSubstring) == 0) { // Case-sensitive check
            printf("%-30s %-15s %-50s\n", contacts[i].name, contacts[i].phone, contacts[i].email);
            found = 1;
        }
