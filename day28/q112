//A program to Create contact management system

#include<stdio.h>
#include<string.h>

#define MAX_CONTACTS 100
// Defining the structure to store contact data
typedef struct {
    char name[50];
    char phone[15];
    char email[50];
} Contact;

// Global array and counter to keep track of records
Contact contacts[MAX_CONTACTS];
int contact_count = 0;

// Function declarations
void addContact();
void displayContacts();

int main() {
    int choice;

    while (1) {
        printf("\n=== Contact Management System ===\n");
        printf("1. Add Contact\n");
        printf("2. Display All Contacts\n");
        printf("3. Exit\n");
        printf("Enter your choice (1-3): ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                addContact();
                break;
            case 2:
                displayContacts();
                break;
            case 3:
                printf("Exiting program. Goodbye!\n");
                return 0;
            default:
                printf("Invalid choice! Please try again.\n");
        }
    }
    return 0;
}

// 1. Function to add a new contact
void addContact() {
    if (contact_count >= MAX_CONTACTS) {
        printf("Contact database is full. Cannot add more records.\n");
        return;
    }

    Contact c;
    printf("\nEnter Contact Name: ");
    scanf(" %[^\n]%*c", c.name); // Read string with spaces
    printf("Enter Phone Number: ");
    scanf("%s", c.phone);
    printf("Enter Email Address: ");
    scanf("%s", c.email);

    // Save to global array
    contacts[contact_count] = c;
    contact_count++;

    printf("Contact added successfully!\n");
}

// 2. Function to display all contacts
void displayContacts() {
    if (contact_count == 0) {
        printf("\nNo contact records found to display.\n");
        return;
    }

    printf("\n%-30s %-15s %-50s\n", "Name", "Phone", "Email");
    printf("-------------------------------------------------------------------------------\n");
    for (int i = 0; i < contact_count; i++) {
        printf("%-30s %-15s %-50s\n", contacts[i].name, contacts[i].phone, contacts[i].email);
    }
}

// 3. Function to search for a contact by name
void searchContact() {
    if (contact_count == 0) {
        printf("\nNo contact records found to search.\n");
        return;
    }

    char searchName[50];
    printf("\nEnter the Contact Name to search: ");
    scanf(" %[^\n]%*c", searchName);

    printf("\nSearch Results for Contact Name '%s':\n", searchName);
    printf("%-30s %-15s %-50s\n", "Name", "Phone", "Email");
    printf("-------------------------------------------------------------------------------\n");
    int found = 0;
    for (int i = 0; i < contact_count; i++) {
        if (strstr(contacts[i].name, searchName) != NULL) { // Case-sensitive search
            printf("%-30s %-15s %-50s\n", contacts[i].name, contacts[i].phone, contacts[i].email);
            found = 1;
        }
    }
    if (!found) {
        printf("No contacts found with name '%s'.\n", searchName);
    }
}

// 4. Function to delete a contact by name
void deleteContact() {
    if (contact_count == 0) {
        printf("\nNo contact records found to delete.\n");
        return;
    }

    char deleteName[50];
    printf("\nEnter the Contact Name to delete: ");
    scanf(" %[^\n]%*c", deleteName);

    for (int i = 0; i < contact_count; i++) {
        if (strcmp(contacts[i].name, deleteName) == 0) {
            // Shift all subsequent records left to overwrite the deleted record
            for (int j = i; j < contact_count - 1; j++) {
                contacts[j] = contacts[j + 1];
            }
            contact_count--;
            printf("Contact with name '%s' deleted successfully.\n", deleteName);
            return;
        }
    }
    printf("Contact with name '%s' not found.\n", deleteName);
}

// 5. Function to update a contact by name
void updateContact() {
    if (contact_count == 0) {
        printf("\nNo contact records found to update.\n");
        return;
    }

    char updateName[50];
    printf("\nEnter the Contact Name to update: ");
    scanf(" %[^\n]%*c", updateName);

    for (int i = 0; i < contact_count; i++) {
        if (strcmp(contacts[i].name, updateName) == 0) {
            printf("Updating record for Contact Name: %s\n", updateName);
            printf("Enter new Phone Number (current: %s): ", contacts[i].phone);
            scanf("%s", contacts[i].phone);
            printf("Enter new Email Address (current: %s): ", contacts[i].email);
            scanf("%s", contacts[i].email);

            printf("Contact record updated successfully!\n");
            return;
        }
    }
    printf("Contact with name '%s' not found.\n", updateName);
}

// 6. Function to display contacts sorted by name in alphabetical order
void displayContactsSortedByName() {
    if (contact_count == 0) {
        printf("\nNo contact records found to display.\n");
        return;
    }

    // Create a copy of the contacts array for sorting
    Contact sortedContacts[MAX_CONTACTS];
    memcpy(sortedContacts, contacts, sizeof(Contact) * contact_count);

    // Sort the contacts by name using bubble sort
    for (int i = 0; i < contact_count - 1; i++) {
        for (int j = 0; j < contact_count - i - 1; j++) {
            if (strcmp(sortedContacts[j].name, sortedContacts[j + 1].name) > 0) {
                Contact temp = sortedContacts[j];
                sortedContacts[j] = sortedContacts[j + 1];
                sortedContacts[j + 1] = temp;
            }
        }
    }

    printf("\nContacts Sorted by Name (Alphabetical Order):\n");
    printf("%-30s %-15s %-50s\n", "Name", "Phone", "Email");
    printf("-------------------------------------------------------------------------------\n");
    for (int i = 0; i < contact_count; i++) {
        printf("%-30s %-15s %-50s\n", sortedContacts[i].name, sortedContacts[i].phone, sortedContacts[i].email);
    }
}

// 7. Function to display contacts with a specific email domain
void displayContactsByEmailDomain() {
    if (contact_count == 0) {
