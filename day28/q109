//10. Function to search for books by title
void searchBookByTitle() {
    if (book_count == 0) {
        printf("\nNo book records found to search.\n");
        return;
    }

    char searchTitle[100];
    printf("\nEnter the Book Title to search: ");
    scanf(" %[^\n]%*c", searchTitle);

    printf("\nSearch Results for Title '%s':\n", searchTitle);
    printf("%-10s %-30s %-20s %-10s %-10s\n", "ID", "Title", "Author", "Year", "Available");
    printf("--------------------------------------------------------------------------\n");
    int found = 0;
    for (int i = 0; i < book_count; i++) {
        if (strstr(books[i].title, searchTitle) != NULL) { // Case-sensitive search
            printf("%-10d %-30s %-20s %-10d %-10s\n", books[i].id, books[i].title, books[i].author, books[i].year, books[i].available ? "Yes" : "No");
            found = 1;
        }
    }
    if (!found) {
        printf("No books found with title containing '%s'.\n", searchTitle);
    }
}

