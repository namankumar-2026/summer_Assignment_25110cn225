//A program to Create bank account system

#include <stdio.h>
#include <string.h>
#define MAX_ACCOUNTS 100
// Defining the structure to store bank account data
typedef struct {
    int accountNumber;
    char accountHolder[50];
    float balance;
} BankAccount;

// Global array and counter to keep track of records
BankAccount accounts[MAX_ACCOUNTS];
int accountCount = 0;

// Function declarations
void addAccount();
void displayAccounts();
void searchAccount();

int main() {
    int choice;

    while (1) {
        printf("\n=== Bank Account Management System ===\n");
        printf("1. Add Bank Account\n");
        printf("2. Display All Bank Accounts\n");
        printf("3. Search Bank Account by Account Number\n");
        printf("4. Exit\n");
        printf("Enter your choice (1-4): ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                addAccount();
                break;
            case 2:
                displayAccounts();
                break;
            case 3:
                searchAccount();
                break;
            case 4:
                printf("Exiting program. Goodbye!\n");
                return 0;
            default:
                printf("Invalid choice! Please try again.\n");
        }
    }
    return 0;
}

// 1. Function to add a new bank account
void addAccount() {
    if (accountCount >= MAX_ACCOUNTS) {
        printf("Bank account database is full. Cannot add more records.\n");
        return;
    }

    BankAccount a;
    printf("\nEnter Account Number: ");
    scanf("%d", &a.accountNumber);
    printf("Enter Account Holder Name: ");
    scanf(" %[^\n]%*c", a.accountHolder); // Read string with spaces
    printf("Enter Initial Balance: ");
    scanf("%f", &a.balance);

    // Save to global array
    accounts[accountCount] = a;
    accountCount++;

    printf("Bank account added successfully!\n");
}

// 2. Function to display all bank accounts
void displayAccounts() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to display.\n");
        return;
    }

    printf("\nBank Account Records:\n");
    printf("%-15s %-30s %-10s\n", "Account Number", "Account Holder", "Balance");
    printf("---------------------------------------------------------------\n");
    for (int i = 0; i < accountCount; i++) {
        printf("%-15d %-30s %-10.2f\n", accounts[i].accountNumber, accounts[i].accountHolder, accounts[i].balance);
    }
}

// 3. Function to search for a bank account by account number
void searchAccount() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to search.\n");
        return;
    }

    int searchAccountNumber;
    printf("\nEnter the Account Number to search: ");
    scanf("%d", &searchAccountNumber);

    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].accountNumber == searchAccountNumber) {
            printf("\nBank Account Found:\n");
            printf("Account Number: %d\n", accounts[i].accountNumber);
            printf("Account Holder: %s\n", accounts[i].accountHolder);
            printf("Balance: %.2f\n", accounts[i].balance);
            return;
        }
    }
    printf("Bank account with Account Number %d not found.\n", searchAccountNumber);
}

//4. Function to deposit money into a bank account
void depositMoney() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to deposit money.\n");
        return;
    }

    int accountNumber;
    float amount;
    printf("\nEnter the Account Number to deposit money: ");
    scanf("%d", &accountNumber);
    printf("Enter the amount to deposit: ");
    scanf("%f", &amount);

    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].accountNumber == accountNumber) {
            accounts[i].balance += amount;
            printf("Amount %.2f deposited successfully! New Balance: %.2f\n", amount, accounts[i].balance);
            return;
        }
    }
    printf("Bank account with Account Number %d not found.\n", accountNumber);
}

//5. Function to withdraw money from a bank account
void withdrawMoney() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to withdraw money.\n");
        return;
    }

    int accountNumber;
    float amount;
    printf("\nEnter the Account Number to withdraw money: ");
    scanf("%d", &accountNumber);
    printf("Enter the amount to withdraw: ");
    scanf("%f", &amount);

    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].accountNumber == accountNumber) {
            if (accounts[i].balance >= amount) {
                accounts[i].balance -= amount;
                printf("Amount %.2f withdrawn successfully! New Balance: %.2f\n", amount, accounts[i].balance);
            } else {
                printf("Insufficient funds in the account.\n");
            }
            return;
        }
    }
    printf("Bank account with Account Number %d not found.\n", accountNumber);
}

//6. Function to delete a bank account
void deleteAccount() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to delete.\n");
        return;
    }

    int accountNumber;
    printf("\nEnter the Account Number to delete: ");
    scanf("%d", &accountNumber);

    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].accountNumber == accountNumber) {
            // Shift all subsequent records left to overwrite the deleted record
            for (int j = i; j < accountCount - 1; j++) {
                accounts[j] = accounts[j + 1];
            }
            accountCount--;
            printf("Bank account with Account Number %d deleted successfully.\n", accountNumber);
            return;
        }
    }
    printf("Bank account with Account Number %d not found.\n", accountNumber);
}

//7. Function to update a bank account
void updateAccount() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to update.\n");
        return;
    }

    int accountNumber;
    printf("\nEnter the Account Number to update: ");
    scanf("%d", &accountNumber);

    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].accountNumber == accountNumber) {
            printf("Updating record for Account Number: %d\n", accountNumber);
            printf("Enter new Account Holder Name (current: %s): ", accounts[i].accountHolder);
            scanf(" %[^\n]%*c", accounts[i].accountHolder); // Read string with spaces
            printf("Enter new Balance (current: %.2f): ", accounts[i].balance);
            scanf("%f", &accounts[i].balance);

            printf("Bank account record updated successfully!\n");
            return;
        }
    }
    printf("Bank account with Account Number %d not found.\n", accountNumber);
}

//8. Function to display bank accounts with balance above a certain threshold
void displayAccountsAboveThreshold() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to display.\n");
        return;
    }

    float threshold;
    printf("\nEnter the balance threshold: ");
    scanf("%f", &threshold);

    printf("\nBank Accounts with Balance above %.2f:\n", threshold);
    printf("%-15s %-30s %-10s\n", "Account Number", "Account Holder", "Balance");
    printf("---------------------------------------------------------------\n");
    int found = 0;
    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].balance > threshold) {
            printf("%-15d %-30s %-10.2f\n", accounts[i].accountNumber, accounts[i].accountHolder, accounts[i].balance);
            found = 1;
        }
    }
    if (!found) {
        printf("No bank accounts found with balance above %.2f.\n", threshold);
    }
}

