//13. Function to display the total balance of all bank accounts
void displayTotalBalance() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to calculate total balance.\n");
        return;
    }

    float totalBalance = 0.0;
    for (int i = 0; i < accountCount; i++) {
        totalBalance += accounts[i].balance;
    }

    printf("\nTotal Balance of All Bank Accounts: %.2f\n", totalBalance);
}

//14. Function to display the average balance of all bank accounts
void displayAverageBalance() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to calculate average balance.\n");
        return;
    }

    float totalBalance = 0.0;
    for (int i = 0; i < accountCount; i++) {
        totalBalance += accounts[i].balance;
    }

    float averageBalance = totalBalance / accountCount;
    printf("\nAverage Balance of All Bank Accounts: %.2f\n", averageBalance);
}

//15. Function to display the bank account with the highest balance
void displayHighestBalanceAccount() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to determine the highest balance.\n");
        return;
    }

    int highestIndex = 0;
    for (int i = 1; i < accountCount; i++) {
        if (accounts[i].balance > accounts[highestIndex].balance) {
            highestIndex = i;
        }
    }

    printf("\nBank Account with the Highest Balance:\n");
    printf("Account Number: %d\n", accounts[highestIndex].accountNumber);
    printf("Account Holder: %s\n", accounts[highestIndex].accountHolder);
    printf("Balance: %.2f\n", accounts[highestIndex].balance);
}