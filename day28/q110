//10. Function to display bank accounts with balance in a specific range
void displayAccountsInRange() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to display.\n");
        return;
    }

    float lowerBound, upperBound;
    printf("\nEnter the lower balance bound: ");
    scanf("%f", &lowerBound);
    printf("Enter the upper balance bound: ");
    scanf("%f", &upperBound);

    printf("\nBank Accounts with Balance in the range %.2f - %.2f:\n", lowerBound, upperBound);
    printf("%-15s %-30s %-10s\n", "Account Number", "Account Holder", "Balance");
    printf("---------------------------------------------------------------\n");
    int found = 0;
    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].balance >= lowerBound && accounts[i].balance <= upperBound) {
            printf("%-15d %-30s %-10.2f\n", accounts[i].accountNumber, accounts[i].accountHolder, accounts[i].balance);
            found = 1;
        }
    }
    if (!found) {
        printf("No bank accounts found with balance in the range %.2f - %.2f.\n", lowerBound, upperBound);
    }
}

//11. Function to display bank accounts with a specific account holder name
void displayAccountsByHolderName() {
    if (accountCount == 0) {
        printf("\nNo bank account records found to display.\n");
        return;
    }

    char searchHolder[50];
    printf("\nEnter the Account Holder Name to search: ");
    scanf(" %[^\n]%*c", searchHolder);

    printf("\nBank Accounts for Account Holder '%s':\n", searchHolder);
    printf("%-15s %-30s %-10s\n", "Account Number", "Account Holder", "Balance");
    printf("---------------------------------------------------------------\n");
    int found = 0;
    for (int i = 0; i < accountCount; i++) {
        if (strstr(accounts[i].accountHolder, searchHolder) != NULL) { // Case-sensitive search
            printf("%-15d %-30s %-10.2f\n", accounts[i].accountNumber, accounts[i].accountHolder, accounts[i].balance);
            found = 1;
        }
    }
    if (!found) {
        printf("No bank accounts found for Account Holder '%s'.\n", searchHolder);
    }
}

