//a program to Recursive factorial
#include<stdio.h>
int factorial(int n) // Function to calculate factorial recursively
{
    if (n == 0 || n == 1) // Base case: factorial of 0 or 1 is 1
        return 1;
    else
        return n * factorial(n - 1); // Recursive case: n! = n * (n-1)!
}
int main()
{
    int n; // Declare a variable to store the number for which factorial is to be calculated
    printf("Enter a number: "); // Prompt the user to enter a number
    scanf("%d", &n); // Read the number from the user

    if (n < 0) // Check if the input number is negative
    {
        printf("Factorial is not defined for negative numbers."); // Print an error message for negative input
    }
    else
    {
        int result = factorial(n); // Call the factorial function and store the result
        printf("Factorial of %d is %d", n, result); // Print the factorial result
    }
    
    return 0; 
}