//Program to check the armstrong numbers
#include<stdio.h>
int main()
{
    int num, originalNum, remainder, result = 0; // Declare variables to store the number, its original value, the remainder, and the result of the calculation
    printf("Enter an integer: "); // Prompt the user to enter an integer
    scanf("%d", &num); // Read the integer from the user

    originalNum = num; // Store the original number for later comparison

    while (originalNum != 0) // Loop until all digits have been processed
    {
        remainder = originalNum % 10; // Get the last digit of the number
        result += remainder * remainder * remainder; // Add the cube of the digit to the result
        originalNum /= 10; // Remove the last digit from the number
    }

    if (result == num) // Check if the calculated result is equal to the original number
        printf("%d is an Armstrong number.", num); // If true, print that it is an Armstrong number
    else
        printf("%d is not an Armstrong number.", num); // If false, print that it is not an Armstrong number

    return 0; 
}