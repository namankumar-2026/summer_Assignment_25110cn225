//A program to write function for armstrong

#include<stdio.h>
int isArmstrong(int num)
{
    int originalNum, remainder, result = 0;
    originalNum = num;

    while (originalNum != 0)
    {
        remainder = originalNum % 10; // Get the last digit
        result += remainder * remainder * remainder; // Add the cube of the digit to the result
        originalNum /= 10; // Remove the last digit
    }

    return result == num; // Check if the result is equal to the original number
}
int main()
{
    int num;
    printf("Enter a number: "); // Prompt the user to enter a number
    scanf("%d", &num); // Read the number from the user

    if (isArmstrong(num)) // Call the isArmstrong function and check its return value
        printf("%d is an Armstrong number.\n", num); // If true, print that it is an Armstrong number
    else
        printf("%d is not an Armstrong number.\n", num); // If false, print that it is not an Armstrong number

    return 0; 
}