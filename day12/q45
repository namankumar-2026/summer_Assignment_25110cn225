//A program to write function for palindrome.
#include<stdio.h>
int isPalindrome(int num)
{
    int originalNum = num; // Store the original number
    int reversedNum = 0; // Initialize the variable to store the reversed number

    while (num > 0) // Loop until the number becomes 0
    {
        int digit = num % 10; // Get the last digit of the number
        reversedNum = reversedNum * 10 + digit; // Append the digit to the reversed number
        num /= 10; // Remove the last digit from the number
    }

    return originalNum == reversedNum; // Check if the original number is equal to the reversed number
}
int main()
{
    int num;
    printf("Enter a number: "); // Prompt the user to enter a number
    scanf("%d", &num); // Read the number from the user

    if (isPalindrome(num)) // Call the isPalindrome function and check its return value
        printf("%d is a palindrome number.\n", num); // If true, print that it is a palindrome number
    else
        printf("%d is not a palindrome number.\n", num); // If false, print that it is not a palindrome number

    return 0; 
}