//A program to write function for perfect number

#include<stdio.h>
int isPerfect(int n)
{
    int sum = 0;
    for (int i = 1; i < n; i++) // Loop through numbers less than n
    {
        if (n % i == 0) // Check if i is a divisor of n
            sum += i; // Add the divisor to the sum
    }
    return sum == n; // Return true if the sum of divisors equals n
}
int main()
{
    int n;
    printf("Enter a number: ");
    scanf("%d", &n);
    if (isPerfect(n))
        printf("%d is a perfect number.\n", n);
    else
        printf("%d is not a perfect number.\n", n);
    return 0;
}