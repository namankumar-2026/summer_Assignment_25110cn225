//A program to write function for fibonacci

#include<stdio.h>
int fibonacci(int n)
{
    if (n == 0) // Base case: Fibonacci of 0 is 0
        return 0;
    else if (n == 1) // Base case: Fibonacci of 1 is 1
        return 1;
    else
        return fibonacci(n - 1) + fibonacci(n - 2); // Recursive case: F(n) = F(n-1) + F(n-2)
}
int main()
{
    int n;
    printf("Enter the number of terms: ");
    scanf("%d", &n);
    printf("Fibonacci sequence: ");
    for (int i = 0; i < n; i++)
    {
        printf("%d ", fibonacci(i));
    }
    return 0;
}